{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  // config:best-practices gives us the whole maintainability spine in one line:
  // config:recommended + dependency dashboard, GitHub Actions & Docker digest
  // pinning (helpers:pinGitHubActionDigests replaces what dependabot.yml did),
  // dev-dependency pinning, automatic config-migration PRs, abandoned-package
  // detection, and weekly lock-file maintenance.
  extends: ["config:best-practices"],

  // Internal dependencies pin to an exact version. The packageRules below carve
  // out the things that are NOT dependencies but compatibility floors.
  rangeStrategy: "pin",

  // CI (the `check` gate) is the arbiter of whether an update is good.
  // platformAutomerge (default true) enqueues GitHub's native auto-merge, which
  // respects the no-bypass branch ruleset on main and merges only on a green
  // `check`. With the 7-day age gate below, this is the zero-intervention loop.
  automerge: true,
  dependencyDashboard: true,

  packageRules: [
    {
      // Supply-chain-attack protection: never act on a release until it has
      // been public for 7 days. Kept realm-wide and deliberately aligned with
      // bunfig.toml's own `minimumReleaseAge = 604800` — bun enforces the same
      // 7 days at install time, so if Renovate proposed anything younger, bun
      // would refuse to resolve it and bun.lock could never regenerate. For
      // GitHub Actions and PyPI/uv (no install-time gate) this is the only gate.
      matchPackageNames: ["*"],
      minimumReleaseAge: "7 days",
    },
    {
      // External requirements are compatibility floors, not pinned dependencies.
      // `requires-python` declares the Python range commy supports;
      // `build-system.requires` declares the minimum build tooling. Both must
      // stay `>=` floors — pinning them to one exact version would wrongly
      // narrow which interpreters and build environments we accept. Renovate
      // leaves them to deliberate human change.
      matchDepTypes: ["requires-python", "build-system.requires"],
      enabled: false,
    },
  ],
}
