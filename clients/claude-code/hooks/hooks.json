{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_commy_commy__(post|edit_message|react|unreact|current_identity)",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/inject-session-id.ts"]
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "commy",
            "tool": "current_identity",
            "input": {
              "session_id": "${session_id}",
              "cwd": "${cwd}"
            }
          }
        ]
      }
    ]
  }
}
