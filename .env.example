# Live integration test credentials for the Zulip adapter live suite
# (packages/zulip/*.live.test.ts).
#
# Copy this file to .env.local and fill in the values for your own Zulip
# realm. direnv loads .env.local automatically on `cd` (see .envrc). With
# these vars in scope, the live suite runs against the configured realm —
# the identity acquire/release tests and the multi-adapter event-delivery
# tests. Without them the suite skips silently and the default `bun test`
# run stays green.
#
# What each var is for:
#   ZULIP_SITE           - base URL of the Zulip realm the tests target.
#   ZULIP_MINTER_*       - credentials for the bot account that mints and
#                          tears down ephemeral test bots per test run.
#   ZULIP_LIVE_CHANNEL_* - an existing channel the tests post into and observe.

ZULIP_SITE=https://your-realm.zulipchat.com
ZULIP_MINTER_EMAIL=minter-bot@your-realm.zulipchat.com
ZULIP_MINTER_API_KEY=
ZULIP_LIVE_CHANNEL_NAME=
ZULIP_LIVE_CHANNEL_ID=
