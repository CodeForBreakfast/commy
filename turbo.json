{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "//#build": {
      "inputs": [
        "packages/**/*.ts",
        "!packages/**/*.test.ts",
        "clients/claude-code/hooks/inject-session-id.ts",
        "package.json",
        "!**/node_modules/**"
      ],
      "outputs": ["packages/mcp/dist/**", "clients/claude-code/dist/**"]
    },
    "//#typecheck": {
      "inputs": ["**/*.ts", "tsconfig*.json", "!**/node_modules/**", "!.worktrees/**"]
    },
    "//#lint": {
      "dependsOn": ["//#typecheck"],
      "inputs": [
        "**/*.ts",
        "**/*.json",
        "!.beads/**",
        "biome.json",
        "!**/node_modules/**",
        "!.worktrees/**"
      ]
    },
    "//#test": {
      "dependsOn": ["//#lint", "//#test:hermes"],
      "inputs": [
        "**/*.ts",
        "**/*.json",
        "!.beads/**",
        "bunfig.toml",
        "**/*.workflow.js",
        "!**/node_modules/**",
        "!.worktrees/**"
      ]
    },
    "//#test:hermes": {
      "inputs": ["clients/hermes/**", "!clients/hermes/.venv/**", "!**/__pycache__/**"]
    }
  }
}
